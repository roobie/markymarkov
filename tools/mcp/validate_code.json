{
  "name": "validate_code",
  "version": "0.1",
  "description": "Run validators on code and return LSP-style diagnostics.",
  "handler": "markymarkov.api.validate.run",
  "inputs": {
    "code": { "type": "string", "required": false },
    "filename": { "type": "string", "required": false },
    "language": { "type": "string", "required": false },
    "model_path": { "type": "string", "required": false },
    "validators": { "type": "array", "items": { "type": "string" }, "required": false }
  },
  "outputs": {
    "diagnostics": { "type": "array", "items": { "type": "object" } },
    "summary": { "type": "string" },
    "confidence": { "type": "number" }
  }
}
